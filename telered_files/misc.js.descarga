	//END Cargar contenido en el modal

	//Fix footer
	//Si hay poco contenido, evita que el footer aparezca antes del bottom de la pantalla
	var footertofooter = function(){
		var totop = $('#allfooter').offset().top;
		var tobottom = $(window).height() - totop - $('#allfooter').height() + $('#maincontent').height();
		if ( tobottom > $('#maincontent').height() ) {
			$('#maincontent').css('minHeight',tobottom);
		};
	};
	$(window).on('load',function() {
		footertofooter();
	});
	//END Fix footer

	$(function(){
		// Detectar si está en standalone mode
		if (window.matchMedia('(display-mode: standalone)').matches) {
			//standalone
			$(document).on('click', 'a[target="_blank"][href^="https://www.telered.com.ar"]', function(e){
				e.preventDefault();
				window.location.href = this.href;
			});
		}
	});

	$(function(){
		// Detectar si se puede hacer scroll en la ventana de canales
		if ( $('.xxxchannelsbrickscontainer').length > 0 ) {
			//hay canales
			var chscroll = $('.xxxchannelsbrickscontainer').get(0).scrollHeight > $('.xxxchannelscontainer').height();
			if (chscroll) {
				$('.sombrascroll').css('display','block');
			};
		}
	});
});

//Mensajes al usuario
function mensajeAlUsuario(tipo,msg){
	//Mensaje al usuario
	if (tipo) {
		//Todo salió bien
		var clasmsg = 'correcto';
		if (!msg) {
			msg = 'Correcto';
		}
	} else {
		//Error
		var clasmsg = 'incorrecto';
		if (!msg) {
			msg = 'Ocurrió un error. Volvé a intentarlo más tarde, por favor.';
		}
	}
	$('body').append("<div class='mensaje " + clasmsg + "'><p>" + msg + "</p></div>");
	setTimeout(function(){
		$('.mensaje').fadeOut(function() {
			$('.mensaje').remove();
		});
	}, 5000);
};
//END Mensajes al usuario

//Lazy load
(function($) {
	$.fn.unveil = function(threshold, callback) {

		var $w = $(window),
			th = threshold || 0,
			retina = window.devicePixelRatio > 1,
			attrib = retina? "data-src-retina" : "data-src",
			images = this,
			loaded;

		this.one("unveil", function() {
			var source = this.getAttribute(attrib);
			source = source || this.getAttribute("data-src");
			if (source) {
			var element_type = this.tagName.toLowerCase();
			if (element_type=="img") {
				this.setAttribute("src", source);
			} else {
				this.style.backgroundImage = "url("+source+")";
			}
			if (typeof callback === "function") callback.call(this);
			}
		});

		function unveil() {
			var inview = images.filter(function() {
			var $e = $(this);
			if ($e.is(":hidden")) return;

			var wt = $w.scrollTop(),
				wb = wt + $w.height(),
				et = $e.offset().top,
				eb = et + $e.height();

			return eb >= wt - th && et <= wb + th;
			});

			loaded = inview.trigger("unveil");
			images = images.not(loaded);
		}

		$w.on("scroll.unveil resize.unveil lookup.unveil", unveil);

		unveil();

		return this;

	};
})(jQuery);

$(function(){
	$("img[src='/img/blank.gif']").unveil(200);//Carga las imágenes lazy
	$('.xxxchannelsbrick header.lazybg').unveil(200);//Carga las imágenes de fondo lazy
});
//END Lazy load
