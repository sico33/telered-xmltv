	function AnalyticsConcurso(AnalyticsConcursoID,Name) {
		return true;
		//Track concurso en Google Universal Analytics
		var pathname = window.location.pathname; //tomo el path de la página que se trackea originalmente
		if ( Name ) {
			var name = Name.replace("%20", "-"); //hago más legible el nombre del concurso, para usarlo como hash
		};

		if ( AnalyticsConcursoID ) {
			//Se abre un form de concurso
			ga('send', 'pageview', '/formConcurso'+AnalyticsConcursoID+'-'+name); //trackeo la página de ese concurso en particular
		} else {
			//Se cerró el form de un concurso
			ga('send', 'pageview', pathname); //Vuelvo a trackear la página original en la que estoy
		};
	}


