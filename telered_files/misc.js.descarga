$(document).ready(function() {

	// Mensaje de formularios
	$(function(){
		setTimeout(function(){
			$('.mensaje').fadeOut(function() {
				$('.mensaje').remove();
			});
		}, 5000);
	});
	// END Mensaje de formularios

	//Medir el ancho del scroll
	function getScrollBarWidth() {
		var inner = document.createElement('p');
		inner.style.width = "100%";
		inner.style.height = "200px";

		var outer = document.createElement('div');
		outer.style.position = "absolute";
		outer.style.top = "0px";
		outer.style.left = "0px";
		outer.style.visibility = "hidden";
		outer.style.width = "200px";
		outer.style.height = "150px";
		outer.style.overflow = "hidden";
		outer.appendChild(inner);

		document.body.appendChild(outer);
		var w1 = inner.offsetWidth;
		outer.style.overflow = 'scroll';
		var w2 = inner.offsetWidth;
		if (w1 == w2) w2 = outer.clientWidth;

		document.body.removeChild(outer);

		return (w1 - w2);
	};
	//END Medir el ancho del scroll

	//Cerrar modal
	function CloseModal(){
		$('.modalorigin').removeClass('modalorigin');
		$("#modalcontent").empty();
		$('#modalheader .h1').empty();
		$(".framed").addClass('framed');
		$("#modalcontent").addClass('framed');
		$("#modalcontent.imgmodal").removeClass('imgmodal');
		$('#modalcontentwrapper, #modalheader, #modalcontent, .SnapABug_Button').removeAttr('style');
		$('#modalwrapper').css('display','none');
		$(document).scrollTop(scrollposition);
		$("body").removeAttr( 'style' );
		$(document).scrollTop( scrollposition );
		if ( !$('.loading').hasClass('loaded') ) {
			setTimeout(function(){
				$('.loading').removeClass('loaded');
			}, 400);
		} else {
			$(".loading").removeClass('loaded');
		};
		AnalyticsConcurso(); //Vuelvo a trackear la página original
	}
	$(document).keyup(function(e) {
		if (e.keyCode == 27 && $('#modalwrapper').css("display") == 'block' ) {
			CloseModal();
		}
	});
	$("#closemodal").click(function(link) {
		CloseModal();
	});

	$('#modalwrapper').click(function(event) {
		if( !$(event.target).closest('#modalcontentwrapper').length ) { //Click fuera del modal
			if ( $('#topmobile').css("display") == 'block' && $('#modalwrapper').css("display") == 'block' ) {
				//mobile
				CloseModal();
			};
		};
	});

	$(window).on('popstate',function(event) {
		//History trigger
		var modalvisible = $('#modalcontentwrapper').css('visibility');
		if ( modalvisible != '' && modalvisible == 'visible' ) {
			//está abierto un modal
			CloseModal();
		};
	});
	//END Cerrar modal

	//Función para abrir modal
	function OpenModal(){
		var ScrollBarWidth = getScrollBarWidth();
		$('#modalwrapper').css('display','block');
		//$('#modalcontentwrapper').removeAttr('style');
		$('.SnapABug_Button').css('zIndex',0);
		scrollposition = $(document).scrollTop();
		topscroll = "-"+scrollposition+"px";
		$("body").css({
			height: "100vh",
			width: "100vw",
			width: "calc(100vw - " + ScrollBarWidth + "px)",
			overflow: "hidden",
			position: "fixed",
			top: topscroll,
			right: ScrollBarWidth + "px)"
		});
		setTimeout(function(){
			$('.loading').addClass('loaded');
		}, 400);
	}
	//Función para abrir modal

	//Centrar verticalmente el modal
	//Ubica el modal en la mayor altura posible y verticalmente centrado
	//El centrado horizontal se hace con CSS
	function verticalcenter(){
		$('#modalcontentwrapper, #modalcontent').removeAttr('style');
		var heightwindow = $('#modalwrapper').height();
		var heightmodalcontentwrapper = $('#modalcontentwrapper').height();
		if ( !$('#modalheader').is(':visible') ) {
			var heightmodal = heightwindow;
		} else {
			var heightmodal = heightwindow - $('#modalheader').innerHeight();
		};
		var margintotop = parseInt( ( heightwindow - heightmodalcontentwrapper ) / 2 , 10);
		if ( heightmodal < heightmodalcontentwrapper ) {
			$('#modalcontentwrapper').css('marginTop','0px');
		} else {
			$('#modalcontentwrapper').css('marginTop',margintotop);
		};
		$('#modalcontent').css('maxHeight',heightmodal);
		$('#imginmodal').css('maxHeight',heightmodal);

		if ( margintotop < (heightmodal / 2) ) {
			if ( $('#modalwrapper').is(':visible') ) {
				$('#modalcontentwrapper').css('visibility','visible');
			};
		};
	};

	$(window).resize(function() {
		verticalcenter();
	});
	$(document).on("click", '#verticalcenter', function(){
		verticalcenter();
	});
	//END Centrar verticalmente el modal

