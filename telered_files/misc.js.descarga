		$blockcontainer.find('.xxxcartelprodbannerdesk button.xxxbuttonget, .xxxcartelprodbannermob button.xxxbuttonget').attr('data-price',price_set);

		$blockcontainer.find('.xxxprodbannerdeskimagen, .xxxprodbannermob').css("background-image","url(img/bannersprod/"+background_set+")");

		$blockcontainer.find('.xxxcartelprodbannerdesk img, .xxxcartelprodbannermob img').attr("src","img/ProdIcons/"+pic_set);

		$blockcontainer.find('.xxxcartelprodbannerdesk .switchprod, .xxxcartelprodbannermob .switchprod p').text(switchtchbuttonText_set);

		$blockcontainer.find('.xxxcartelprodbannerdesk .xxxprodbannerdeskinfo p:nth-child(1), .xxxcartelprodbannermob .xxxprodbannermobinfo p:nth-child(1)').html(infoone_set);

		$blockcontainer.find('.xxxcartelprodbannerdesk .xxxprodbannerdeskinfo p:nth-child(2), .xxxcartelprodbannermob .xxxprodbannermobinfo p:nth-child(2)').html(infotwo_set);

		$blockcontainer.find('.xxxcartelprodbannerdesk .xxxprodbannerdesklegal p:nth-child(1), .xxxcartelprodbannermob .side .xxxprodbannermoblegal p').html(legalone_set);

		$blockcontainer.find('.xxxcartelprodbannerdesk .xxxprodbannerdesklegal p:nth-child(2), .xxxcartelprodbannermob .tablerow>.tablecell:not(.side)>.xxxprodbannermoblegal>p').html(legaltwo_set);

		$blockcontainer.find('.xxxcartelprodbannerdesk button.xxxbuttonget, .xxxcartelprodbannermob button.xxxbuttonget').attr('data-productname',intPack_set);

		$blockcontainer.find('.xxxcartelprodbannerdesk button.xxxbuttonget, .xxxcartelprodbannermob button.xxxbuttonget').attr('data-contentid',contentid_set);
	});
